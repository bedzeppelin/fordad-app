# Supabase project settings (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Random secret used to sign the admin session cookie.
# Generate one with: openssl rand -hex 32
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Optional. Without this, voice notes still work but use a simple
# sentence-splitting fallback instead of real AI summarization.
GEMINI_API_KEY=

# Push notifications. Generate with: npm run generate:vapid
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Must match Vercel's auto-injected cron secret — set the same value in
# Vercel's project env vars. Locally, leave blank to skip the check.
CRON_SECRET=

# IANA timezone Dad actually lives in — used to decide "is it 8am yet" for
# reminders. Without this, times are compared in America/New_York.
TIMEZONE=America/New_York
